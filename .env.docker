# =============================================================================
# MANO — Docker environment template
#
# HOW TO USE:
#   cp .env.docker .env
#   Fill in every value marked REQUIRED before running `docker compose up`
#   Never commit the filled-in .env to version control.
# =============================================================================


# ── MySQL (used by both the `db` service and the api DATABASE_URL) ──────────
# REQUIRED — change these before first run
MYSQL_ROOT_PASSWORD=DevPass2024
MYSQL_USER=devuser
MYSQL_PASSWORD=DevPass2024

# DATABASE_URL is constructed automatically in docker-compose.yml from the
# vars above. You do NOT need to set it here.


# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO


# ── CORS ────────────────────────────────────────────────────────────────────
# Add your domain here once you have one (e.g. https://mano.example.com)
# During local docker testing, the defaults below are fine.
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000


# ── Event bus ───────────────────────────────────────────────────────────────
EVENT_BUS_BACKEND=inprocess
KAFKA_BOOTSTRAP_SERVERS=


# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_ML=20/minute
RATE_LIMIT_LLM=10/minute


# ── LLM API keys (all optional — app degrades gracefully without them) ───────
# Google Gemini Flash (free tier: 15 RPM, 1,500 req/day)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq Cloud — Llama 3 (free tier: ~30 RPM)
# https://console.groq.com/keys
GROQ_API_KEY=

# HuggingFace Inference API (free tier: ~1,000 req/day)
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=


# ── Research & evidence (optional) ──────────────────────────────────────────
NCBI_API_KEY=


# ── Ambient audio (optional) ─────────────────────────────────────────────────
FREESOUND_API_KEY=
YOUTUBE_API_KEY=


# ── TF / PyTorch noise suppression ──────────────────────────────────────────
TF_ENABLE_ONEDNN_OPTS=0
TF_CPP_MIN_LOG_LEVEL=2
PYTHONUTF8=1