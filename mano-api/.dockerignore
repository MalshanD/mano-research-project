# Virtual environment — deps are installed fresh inside the container
venv/
.venv/
env/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Environment secrets — never bake into the image
.env
.env.*
!.env.example

# IDE & editor
.idea/
.vscode/
*.swp
*.swo
*~

# Tests — not needed at runtime
tests/
pytest-cache-files-*/
.pytest_cache/
htmlcov/
.coverage
.mypy_cache/
.ruff_cache/

# OS
.DS_Store
Thumbs.db

# Misc
*.bak
*.tmp
*.log
README.md
docs/
