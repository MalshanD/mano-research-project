# =============================================================================
# MANO Backend — Environment Variables (Component 1 enhanced edition)
# =============================================================================
# Copy this file to .env and fill in values as needed.
#
# Design rule: every variable below is OPTIONAL except those marked REQUIRED.
# The app MUST boot and serve every endpoint at a degraded-but-valid level
# with zero external API keys configured. Missing keys trigger graceful
# local fallbacks (template narratives, cached PubMed citations, Mixkit
# sound library, in-memory cache, in-process event bus, etc.).
# =============================================================================


# ── Core runtime ────────────────────────────────────────────────────────────
# REQUIRED: MySQL connection string used by SQLAlchemy.
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/mano_db

# Log level: DEBUG | INFO | WARNING | ERROR. Default: INFO.
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins. Default: localhost dev ports.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173


# ── Cache backend ───────────────────────────────────────────────────────────
# When set, the CacheBackend uses Redis. When unset, falls back to an
# in-memory TTL dict (suitable for development; loses state on restart).
# redis://localhost:6379/0
REDIS_URL=


# ── Event bus backend ───────────────────────────────────────────────────────
# inprocess  → asyncio.Queue-based EventBus (default, zero ops).
# kafka      → aiokafka adapter; requires KAFKA_BOOTSTRAP_SERVERS.
EVENT_BUS_BACKEND=inprocess
KAFKA_BOOTSTRAP_SERVERS=


# ── Rate limiting (slowapi) ────────────────────────────────────────────────
# Per-IP budgets. Values are "N/period" strings supported by slowapi.
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_ML=20/minute
RATE_LIMIT_LLM=10/minute


# ── Large Language Models (all free tiers) ────────────────────────────────
# Google Gemini Flash — free: 15 RPM, 1,500 req/day.
# Used by: C3 chat, therapy Phase 2/3, reframe generation.
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq Cloud (Llama 3 / 3.1 8B) — free: ~30 RPM, 14,400 req/day.
# Used by: Future-Self narrative, therapy Phase 4/7 summaries, voice reflections.
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# HuggingFace Inference API — free: ~1,000 req/day.
# Used by: GoEmotions 6-class emotion classifier.
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=


# ── Research and evidence APIs (no key required, keys lift rate limits) ──
# NCBI PubMed E-utilities API key — optional; raises the 3 rps limit to 10 rps.
# Used by: PubMed evidence cards (Prompt 5).
# Get key: https://www.ncbi.nlm.nih.gov/account/settings/ → "API Key Management"
NCBI_API_KEY=


# ── Ambient audio APIs ──────────────────────────────────────────────────────
# Freesound API key — optional; falls back to curated Mixkit library.
# Used by: ambient sound recommender (Prompt 9).
# Get key: https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=FQGb0ZsQcUoePWTPV0jquNR2De4y3ueXMlJWAvh0

# YouTube Data API v3 — optional; falls back to local meditation list.
# Used by: guided meditation video recommendations (Prompt 9).
# Get key: Google Cloud Console → APIs → YouTube Data API v3 → Credentials.
YOUTUBE_API_KEY=


# ── Email (researcher batch-job notifications) ─────────────────────────────
# Optional. When unset, notifications are skipped (job result is still polled).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=


# ── TensorFlow / PyTorch noise suppression (Windows developer ergonomics) ─
TF_ENABLE_ONEDNN_OPTS=0
TF_CPP_MIN_LOG_LEVEL=2
PYTHONUTF8=1
