# =============================================================================
# MANO API — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
*.whl

# Virtual environments
venv/
.venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.ropeproject/
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# ML Model Files (large binaries — track with Git LFS or download separately)
# ---------------------------------------------------------------------------
*.h5
*.pkl
*.joblib
*.pt
*.pth
*.ckpt
*.weights
*.keras
*.onnx
*.tflite
*.pb
*.savedmodel
*.rar

# Keep JSON config files used by models
!ml_models/**/*.json

# ---------------------------------------------------------------------------
# Logs & Databases
# ---------------------------------------------------------------------------
*.log
*.sqlite3
*.db

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.bak
*.tmp
*.temp